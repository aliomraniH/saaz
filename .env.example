# --- Required ---

# Replit Helium Postgres. Same instance mneme uses; saaz writes to its own
# tables (`artist`, `song`, etc.) and mneme writes to its own (`query_episode`,
# `expertise_note`, etc.). See docs/DATABASE.md.
#
# Internal hostname `helium` only resolves from inside Replit; this URL will
# NOT work from a laptop.
#
# IMPORTANT: do NOT commit the real password. Put the real value in Replit
# Secrets under DATABASE_URL.
DATABASE_URL=postgresql://postgres:password@helium/heliumdb?sslmode=disable

# --- Enrichment providers (at least one recommended) ---

# Anthropic — used for fallback bios + the weekly discovery job.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Perplexity — preferred for socials and recency because Sonar has built-in
# search and citations. Get a key at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# --- Embeddings (one of these) ---

# Voyage handles Persian better. Get a key at https://www.voyageai.com
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# OpenAI fallback. Get a key at https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=text-embedding-3-small

# --- Optional ---

# Vercel Blob token, if you want to mirror image thumbnails. Optional; images
# are stored as URLs only by default.
BLOB_READ_WRITE_TOKEN=
